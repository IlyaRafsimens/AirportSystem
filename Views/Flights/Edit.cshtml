@model AirportSystem.Models.Flight

@{
    ViewData["Title"] = "Правка рейса";
}

<div style="max-width: 800px; margin: 0 auto;">
    <header style="margin-bottom: 40px;">
        <h1 style="font-size: 2.5rem; font-weight: 800; letter-spacing: -1.5px; margin-bottom: 10px;">🛠 Правка рейса @Model.FlightNumber</h1>
        <p style="color: var(--text-muted); font-weight: 600;">Корректировка данных и обновление статуса вылета</p>
    </header>

    <div class="card shadow-lg" style="padding: 40px; border-radius: 40px; background: #fff; border: 1px solid var(--border);">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" style="color: #ef4444; font-weight: 700; margin-bottom: 20px;"></div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                <div style="margin-bottom: 20px;">
                    <label style="display:block; font-size:0.75rem; font-weight:800; color:var(--text-muted); text-transform:uppercase; margin:0 0 10px 15px;">Номер рейса</label>
                    <input asp-for="FlightNumber" style="width:100%; padding:18px; border-radius:20px; border:1px solid var(--bg-app); background:var(--bg-app); font-weight:700; color: var(--primary);" />
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="display:block; font-size:0.75rem; font-weight:800; color:var(--text-muted); text-transform:uppercase; margin:0 0 10px 15px;">Назначение</label>
                    <input asp-for="Destination" style="width:100%; padding:18px; border-radius:20px; border:1px solid var(--bg-app); background:var(--bg-app); font-weight:700;" />
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                <div style="margin-bottom: 20px;">
                    <label style="display:block; font-size:0.75rem; font-weight:800; color:var(--text-muted); text-transform:uppercase; margin:0 0 10px 15px;">Гейт</label>
                    <input asp-for="Gate" style="width:100%; padding:18px; border-radius:20px; border:1px solid var(--bg-app); background:var(--bg-app); font-weight:700;" />
                    <span asp-validation-for="Gate" style="color: #ef4444; font-size: 0.8rem; font-weight: 700; margin-left: 15px;"></span>
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="display:block; font-size:0.75rem; font-weight:800; color:var(--text-muted); text-transform:uppercase; margin:0 0 10px 15px;">Статус рейса</label>
                    <select asp-for="Status" asp-items="Html.GetEnumSelectList<AirportSystem.Models.FlightStatus>()" style="width:100%; padding:18px; border-radius:20px; border:2px solid var(--primary-glow); background:#fff; font-weight:700; color: var(--primary);"></select>
                </div>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 25px;">
                <div style="margin-bottom: 20px;">
                    <label style="display:block; font-size:0.75rem; font-weight:800; color:var(--text-muted); text-transform:uppercase; margin:0 0 10px 15px;">Вылет</label>
                    <input asp-for="ScheduledDeparture" type="datetime-local" style="width:100%; padding:18px; border-radius:20px; border:1px solid var(--bg-app); background:var(--bg-app); font-weight:700;" />
                </div>
                <div style="margin-bottom: 20px;">
                    <label style="display:block; font-size:0.75rem; font-weight:800; color:var(--text-muted); text-transform:uppercase; margin:0 0 10px 15px;">Вместимость</label>
                    <input asp-for="MaxSeats" type="number" style="width:100%; padding:18px; border-radius:20px; border:1px solid var(--bg-app); background:var(--bg-app); font-weight:700;" />
                </div>
            </div>

            <div style="display: flex; gap: 20px; margin-top: 30px;">
                <button type="submit" class="card" style="flex: 2; background: var(--primary); color: #fff; border: 0; padding: 20px; font-weight: 800; cursor: pointer;">ОБНОВИТЬ ДАННЫЕ</button>
                <a asp-action="Index" class="card" style="flex: 1; background: #fff; color: var(--text-muted); text-decoration: none; text-align: center; padding: 20px; font-weight: 800; border: 1px solid var(--border);">НАЗАД</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}