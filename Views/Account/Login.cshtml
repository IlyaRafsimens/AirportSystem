@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ВХОД | AIRPORT.OS</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #007AFF;
            --bg: #F2F4F7;
        }

        body {
            margin: 0;
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-card {
            width: 100%;
            max-width: 440px;
            background: white;
            padding: 60px 50px;
            border-radius: 60px;
            box-shadow: 0 40px 100px rgba(0,0,0,0.06);
            text-align: center;
            box-sizing: border-box;
            position: relative;
        }

        .brand {
            color: var(--primary);
            font-weight: 900;
            font-size: 2rem;
            letter-spacing: -2px;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        h1 {
            font-size: 2.2rem;
            font-weight: 900;
            margin-bottom: 35px;
            letter-spacing: -1.5px;
            color: #1d1d1f;
        }

        input {
            width: 100%;
            padding: 22px 25px;
            border-radius: 24px;
            border: 2px solid transparent;
            background: #E8F0FE;
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 15px;
            box-sizing: border-box;
            font-family: inherit;
            transition: 0.3s;
        }

            input:focus {
                outline: none;
                border-color: var(--primary);
                background: white;
            }

        .btn-login {
            width: 100%;
            padding: 22px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 24px;
            font-size: 1.1rem;
            font-weight: 800;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 10px;
            box-shadow: 0 10px 30px rgba(0, 122, 255, 0.3);
        }

            .btn-login:hover {
                transform: translateY(-2px);
                box-shadow: 0 15px 40px rgba(0, 122, 255, 0.4);
            }

        .footer-nav {
            margin-top: 40px;
            display: flex;
            flex-direction: column;
            gap: 15px;
            align-items: center;
        }

        .link-reg {
            color: var(--primary);
            text-decoration: none;
            font-weight: 800;
            font-size: 0.95rem;
        }

        .btn-back-home {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 25px;
            background: #f5f5f7;
            color: #86868b;
            text-decoration: none;
            border-radius: 16px;
            font-weight: 700;
            font-size: 0.85rem;
            transition: 0.3s;
        }

            .btn-back-home:hover {
                background: #eee;
                color: #1d1d1f;
            }

        .error-msg {
            color: #ff3b30;
            font-weight: 700;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="brand">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3.5c-.5-.5-2.5 0-4 1.5L13.5 8.5 5.3 6.7c-1.1-.3-2.2.4-2.5 1.5l-.5 2 8 3L7 17l-3-1-2 1 4 2 2 4 1-2-1-3 3.8-3.3 3 8 2-.5c1.1-.3 1.8-1.4 1.5-2.5z" /></svg>
            AIRPORT.OS
        </div>
        <h1>Вход в терминал</h1>
        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }
        <form asp-action="Login" method="post">
            <input type="email" name="email" placeholder="Идентификатор (Email)" required />
            <input type="password" name="password" placeholder="Пароль" required />
            <button type="submit" class="btn-login">ВОЙТИ</button>
        </form>
        <div class="footer-nav">
            <a href="/Account/Register" class="link-reg">Создать персональный аккаунт</a>
            <a href="/" class="btn-back-home">Вернуться на главную</a>
        </div>
    </div>
</body>
</html>