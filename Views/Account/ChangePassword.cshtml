@{
    ViewData["Title"] = "Смена пароля";
}

<div style="max-width: 600px; margin: 0 auto;">
    <header style="margin-bottom: 50px;">
        <p style="color: var(--primary); font-weight: 800; letter-spacing: 2px; font-size: 0.8rem;">SECURITY CENTER</p>
        <h1 style="font-size: 3.5rem; font-weight: 900; letter-spacing: -3px; margin: 0;">Change Access Key</h1>
    </header>

    @if (ViewBag.Error != null)
    {
        <div style="background: #ff3b30; color: white; padding: 20px 30px; border-radius: 25px; margin-bottom: 30px; font-weight: 700; box-shadow: 0 10px 30px rgba(255, 59, 48, 0.2);">
            ⚠️ @ViewBag.Error
        </div>
    }

    <div class="card-premier" style="background: white; padding: 50px; border-radius: 50px;">
        <form asp-action="ChangePassword" method="post">
            <div style="margin-bottom: 30px;">
                <label style="display:block; font-size: 0.75rem; font-weight: 800; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; margin-left: 15px;">Текущий пароль</label>
                <input type="password" name="oldPassword" placeholder="••••••••" required
                       style="width:100%; padding:20px; border-radius:20px; border:1px solid #E5E5E7; background:#F5F5F7; font-weight:700; font-size:1.1rem; outline:none;" />
            </div>

            <div style="margin-bottom: 30px;">
                <label style="display:block; font-size: 0.75rem; font-weight: 800; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; margin-left: 15px;">Новый пароль</label>
                <input type="password" name="newPassword" placeholder="Минимум 4 символа" required
                       style="width:100%; padding:20px; border-radius:20px; border:1px solid #E5E5E7; background:#F5F5F7; font-weight:700; font-size:1.1rem; outline:none;" />
            </div>

            <div style="margin-bottom: 40px;">
                <label style="display:block; font-size: 0.75rem; font-weight: 800; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; margin-left: 15px;">Подтвердите новый пароль</label>
                <input type="password" name="confirmPassword" placeholder="••••••••" required
                       style="width:100%; padding:20px; border-radius:20px; border:1px solid #E5E5E7; background:#F5F5F7; font-weight:700; font-size:1.1rem; outline:none;" />
            </div>

            <div style="display: flex; gap: 20px;">
                <button type="submit" class="btn-save" style="flex: 2;">ОБНОВИТЬ КЛЮЧ ДОСТУПА</button>
                <a asp-controller="Home" asp-action="MyProfile" class="btn-cancel" style="flex: 1; text-align: center; display: flex; align-items: center; justify-content: center;">ОТМЕНА</a>
            </div>
        </form>
    </div>
</div>