@{
    Layout = null;
    ViewData["Title"] = "Регистрация";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>РЕГИСТРАЦИЯ | AIRPORT.OS</title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --primary: #007AFF; --bg: #F5F7FA; }
        body { margin: 0; font-family: 'Manrope', sans-serif; background: var(--bg); height: 100vh; display: flex; align-items: center; justify-content: center; }
        .reg-card { width: 100%; max-width: 440px; padding: 50px; background: white; border-radius: 40px; box-shadow: 0 30px 60px rgba(0,0,0,0.05); text-align: center; box-sizing: border-box; }
        .brand { font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 30px; display: flex; align-items: center; justify-content: center; gap: 12px; }
        h1 { font-size: 1.8rem; font-weight: 800; margin-bottom: 30px; }
        input { width: 100%; padding: 18px 25px; margin-bottom: 15px; border-radius: 18px; border: none; background: #F0F2F5; font-size: 0.95rem; font-family: inherit; box-sizing: border-box; }
        .btn { width: 100%; padding: 18px; background: var(--primary); color: white; border: none; border-radius: 18px; font-size: 1rem; font-weight: 800; cursor: pointer; transition: 0.3s; margin-top: 10px; }
        .links { margin-top: 25px; font-weight: 600; font-size: 0.9rem; }
        .links a { color: var(--primary); text-decoration: none; }
        .error { background: #FF3B30; color: white; padding: 10px; border-radius: 10px; margin-bottom: 20px; font-size: 0.8rem; font-weight: 700; }
    </style>
</head>
<body>
    <div class="reg-card">
        <div class="brand">AIRPORT.OS</div>
        <h1>Регистрация</h1>

        @if (ViewBag.Error != null)
        {
            <div class="error">@ViewBag.Error</div>
        }

        <form asp-action="Register" method="post">
            <input type="email" name="email" placeholder="Email сотрудника" required />
            <input type="password" name="password" placeholder="Пароль" required />
            <input type="password" name="confirmPassword" placeholder="Повторите пароль" required />
            <button type="submit" class="btn">ЗАРЕГИСТРИРОВАТЬСЯ</button>
        </form>
        <div class="links">
            <a asp-action="Login">Уже есть доступ? Войти</a>
        </div>
    </div>
</body>
</html>