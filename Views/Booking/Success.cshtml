@model AirportSystem.Models.Ticket
@{
    ViewData["Title"] = "Успех";
}

<div style="text-align: center; margin-top: 50px; animation: fadeIn 0.8s ease-out;">
    <div style="width: 100px; height: 100px; background: #34c759; color: white; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; font-size: 3rem; margin-bottom: 30px; box-shadow: 0 20px 40px rgba(52, 199, 89, 0.2);">✓</div>
    <h1 style="font-size: 3rem; font-weight: 900; letter-spacing: -3px;">Билет Зарегистрирован!</h1>
    <p style="color: var(--text-dim); font-weight: 700; margin-bottom: 40px;">Номер бронирования: <span style="color: var(--primary)">@Model.TicketNumber</span></p>

    <div class="ticket-card" style="max-width: 600px; margin: 0 auto; text-align: left;">
        <div class="ticket-main">
            <div class="label" style="color: var(--primary)">BOARDING PASS</div>
            <div style="font-size: 2rem; font-weight: 900; margin: 10px 0;">@Model.Flight.Destination.ToUpper()</div>
            <p style="font-weight: 700; color: var(--text-dim);">Пассажир: @Model.Passenger.FullName</p>
            <p style="font-weight: 700; color: var(--text-main); margin-top: 10px;">Цена: @Model.FinalPrice.ToString("N2") BYN</p>
        </div>
        <div class="perforation"></div>
        <div class="ticket-stub">
            <img src="@ViewBag.QrCode" style="width: 120px; border-radius: 10px;" />
        </div>
    </div>

    <div style="margin-top: 50px; display: flex; justify-content: center; gap: 20px;">
        <a href="/" class="btn-cancel">НА ГЛАВНУЮ</a>
        <a asp-action="Print" asp-route-id="@Model.Id" class="btn-save">ПЕЧАТЬ PDF</a>
    </div>
</div>