@model AirportSystem.Models.Ticket
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>ПЕЧАТЬ БИЛЕТА | @Model.TicketNumber</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background: #f0f2f5;
            padding: 40px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .ticket {
            width: 850px;
            background: white;
            border-radius: 30px;
            display: flex;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0,0,0,0.1);
            border: 1px solid #ddd;
            position: relative;
        }

        .main {
            flex: 2.5;
            padding: 40px;
            border-right: 3px dashed #eee;
        }

        .stub {
            flex: 1;
            background: #fafafa;
            padding: 40px;
            text-align: center;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
        }

        .brand {
            color: #007AFF;
            font-weight: 900;
            font-size: 1.2rem;
            margin-bottom: 30px;
            letter-spacing: -1px;
        }

        .label {
            font-size: 0.7rem;
            color: #888;
            text-transform: uppercase;
            font-weight: 800;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .val {
            font-size: 1.2rem;
            font-weight: 700;
            margin-bottom: 20px;
            color: #1d1d1f;
        }

        .qr-code {
            width: 140px;
            height: 140px;
            margin-top: 20px;
        }

        .no-print {
            margin-bottom: 30px;
        }

        .btn-print {
            background: #007AFF;
            color: white;
            border: none;
            padding: 15px 40px;
            border-radius: 15px;
            font-weight: 800;
            cursor: pointer;
            font-size: 1rem;
        }

        @@media print {
            body {
                background: white;
                padding: 0;
            }

            .no-print {
                display: none;
            }

            .ticket {
                box-shadow: none;
                border: 2px solid #000;
                margin-top: 0;
            }
        }
    </style>
</head>
<body>

    <div class="no-print">
        <button onclick="window.print()" class="btn-print">ОТПРАВИТЬ НА ПЕЧАТЬ</button>
        <button onclick="window.history.back()" class="btn-print" style="background:#888; margin-left:10px;">НАЗАД</button>
    </div>

    <div class="ticket">
        <div class="main">
            <div class="brand">AIRPORT.OS // ПРЕМЬЕР ДОСТУП</div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                <div>
                    <div class="label">Пассажир</div>
                    <div class="val">@Model.Passenger.FullName</div>
                    <div class="label">Рейс / Flight</div>
                    <div class="val">@Model.Flight.FlightNumber</div>
                </div>
                <div>
                    <div class="label">Назначение</div>
                    <div class="val">@Model.Flight.Destination.ToUpper()</div>
                    <div class="label">Дата и время</div>
                    <div class="val">@Model.Flight.ScheduledDeparture.ToString("f")</div>
                </div>
            </div>
            <div style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #f0f0f0; display: flex; justify-content: space-between;">
                <div>
                    <div class="label">Класс</div>
                    <div class="val">@Model.Class.ToString().ToUpper()</div>
                </div>
                <div style="text-align: right;">
                    <div class="label">Стоимость (BYN)</div>
                    <div class="val">@Model.FinalPrice.ToString("N2")</div>
                </div>
            </div>
        </div>
        <div class="stub">
            <div class="label">Кресло / Seat</div>
            <div style="font-size: 4rem; font-weight: 900; color: #007AFF;">@Model.SeatNumber</div>
            <img src="@ViewBag.QrCode" class="qr-code" />
            <div style="font-family: monospace; font-size: 0.6rem; margin-top: 10px; color: #888;">@Model.TicketNumber</div>
        </div>
    </div>

</body>
</html>