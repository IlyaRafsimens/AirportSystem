@using Microsoft.AspNetCore.Localization
@inject Microsoft.Extensions.Options.IOptions<Microsoft.AspNetCore.Builder.RequestLocalizationOptions> LocOptions

@{
    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    bool isEn = requestCulture.RequestCulture.Culture.Name == "en";
}

<!DOCTYPE html>
<html lang="@requestCulture.RequestCulture.Culture.Name">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | AIRPORT.OS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <aside>
        <div class="brand">
            <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3.5c-.5-.5-2.5 0-4 1.5L13.5 8.5 5.3 6.7c-1.1-.3-2.2.4-2.5 1.5l-.5 2 8 3L7 17l-3-1-2 1 4 2 2 4 1-2-1-3 3.8-3.3 3 8 2-.5c1.1-.3 1.8-1.4 1.5-2.5z" /></svg>
            <span>AIRPORT.OS</span>
        </div>

        <nav>
            <a asp-controller="Home" asp-action="Index">@(isEn ? "Home" : "Главная")</a>
            <a asp-controller="Board" asp-action="Index">@(isEn ? "Live Board" : "Онлайн-табло")</a>

            @if (User.Identity.IsAuthenticated)
            {
                <a asp-controller="Home" asp-action="MyProfile">@(isEn ? "My Profile" : "Мой кабинет")</a>

                @if (User.IsInRole("User"))
                {
                    <a asp-controller="Booking" asp-action="Index">@(isEn ? "Booking" : "Бронирование")</a>
                    <a asp-controller="Registration" asp-action="Index">@(isEn ? "Check-in" : "Регистрация")</a>
                }

                @if (User.IsInRole("Admin"))
                {
                    <a asp-controller="Admin" asp-action="Tickets">@(isEn ? "All Tickets" : "Реестр билетов")</a>
                    <a asp-controller="Admin" asp-action="Blacklist">@(isEn ? "Security" : "Безопасность")</a>
                }

                @if (User.IsInRole("Dispatcher") || User.IsInRole("Admin"))
                {
                    <a asp-controller="Flights" asp-action="Index">@(isEn ? "Flights" : "Диспетчерская")</a>
                    <a asp-controller="Flights" asp-action="Runway">@(isEn ? "Runways" : "Полосы")</a>
                }
            }
        </nav>

        <div style="margin-top: auto; display: flex; flex-direction: column; gap: 15px;">
            <!-- ПЕРЕКЛЮЧАТЕЛЬ RU / EN -->
            <form asp-controller="Language" asp-action="SetLanguage" asp-route-returnUrl="@Context.Request.Path" method="post" style="display: flex; gap: 5px; background: rgba(0,0,0,0.05); padding: 5px; border-radius: 12px;">
                <button name="culture" value="ru" class="@(!isEn ? "active-lang" : "")" style="flex:1; border:none; background:none; cursor:pointer; font-weight:800; font-size:0.7rem; padding:8px;">RU</button>
                <button name="culture" value="en" class="@(isEn ? "active-lang" : "")" style="flex:1; border:none; background:none; cursor:pointer; font-weight:800; font-size:0.7rem; padding:8px;">EN</button>
            </form>

            @await Html.PartialAsync("_LoginPartial")
        </div>
    </aside>

    <main>@RenderBody()</main>

    <style>
        .active-lang {
            background: white !important;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            color: var(--primary);
        }
    </style>
</body>
</html>