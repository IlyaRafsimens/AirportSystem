@model AirportSystem.Models.Ticket
@{
    ViewData["Title"] = "Выбор места";
    var occupied = ViewBag.OccupiedSeats as List<string>;
}

<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: start;">

    <div>
        <p class="label" style="color: var(--primary)">Шаг 2: Оформление</p>
        <h1>Регистрация рейса</h1>

        <div class="card-premier" style="background: white;">
            <h2 style="font-weight: 900; margin-bottom: 5px;">@Model.Flight.Destination</h2>
            <p style="color: var(--text-dim); font-weight: 700; margin-bottom: 30px;">Рейс: @Model.Flight.FlightNumber | Класс: @Model.Class</p>

            <form asp-action="Complete" method="post">
                <input type="hidden" name="ticketId" value="@Model.Id" />

                <div style="margin-bottom: 25px;">
                    <label class="label">Выбранное кресло</label>
                    <input type="text" name="seat" id="selectedSeat" readonly placeholder="Выберите на схеме"
                           style="width: 100%; padding: 20px; border-radius: 20px; border: 2px solid var(--primary); background: #f0f7ff; font-weight: 900; font-size: 1.5rem; text-align: center; color: var(--primary);" required />
                </div>

                <div style="margin-bottom: 35px;">
                    <label class="label">Вес багажа (кг)</label>
                    <input type="number" name="weight" value="0" step="0.1" class="input-ui" />
                    <p style="font-size: 0.7rem; color: var(--text-dim); margin-left: 15px;">* Лимит для вашего класса: @(Model.Class == AirportSystem.Models.TicketClass.Business ? "30кг" : "23кг")</p>
                </div>

                <button type="submit" class="btn-premier" style="width: 100%; font-size: 1.1rem; letter-spacing: 1px;">ЗАВЕРШИТЬ РЕГИСТРАЦИЮ</button>
            </form>
        </div>
    </div>

    <!-- КАРТА МЕСТ -->
    <div class="card-premier" style="background: #E8EDF2; padding: 50px 30px;">
        <h3 style="text-align: center; font-weight: 900; margin-bottom: 40px; letter-spacing: -1px;">Схема салона</h3>

        <div style="display: grid; grid-template-columns: repeat(4, 55px); gap: 12px; justify-content: center; position: relative;">
            @for (int i = 1; i <= 12; i++)
            {
                @foreach (var letter in new[] { "A", "B", "C", "D" })
                {
                    var seatId = i + letter;
                    bool isTaken = occupied != null && occupied.Contains(seatId);

                    <div onclick="if(!@isTaken.ToString().ToLower()){ selectSeat(this, '@seatId') }"
                         class="seat-item"
                         style="width: 55px; height: 60px; background: @(isTaken ? "#BDC3C7" : "white"); border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 800; cursor: @(isTaken ? "not-allowed" : "pointer"); transition: 0.2s; box-shadow: 0 4px 10px rgba(0,0,0,0.05); border: 1px solid rgba(0,0,0,0.05); color: @(isTaken ? "#fff" : "#1d1d1f");">
                        @seatId
                    </div>
                }
            }
        </div>
    </div>

</div>

<script>
    function selectSeat(element, seatId) {
        // Сброс старого выбора
        document.querySelectorAll('.seat-item').forEach(el => {
            if(el.style.background === 'rgb(0, 122, 255)') { // Если синий (primary)
                el.style.background = 'white';
                el.style.color = '#1d1d1f';
            }
        });

        // Новый выбор
        element.style.background = '#007AFF';
        element.style.color = 'white';
        document.getElementById('selectedSeat').value = seatId;
    }
</script>