@{
    Layout = null;
    ViewData["Title"] = "Вход в терминал";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>АВТОРИЗАЦИЯ | AIRPORT.OS</title>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #007AFF;
            --bg: #F5F7FA;
            --white: #FFFFFF;
        }

        body {
            margin: 0;
            font-family: 'Manrope', sans-serif;
            background: var(--bg);
            background-image: radial-gradient(at 0% 0%, rgba(0, 122, 255, 0.1) 0px, transparent 50%), radial-gradient(at 100% 100%, rgba(0, 122, 255, 0.1) 0px, transparent 50%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-box {
            width: 100%;
            max-width: 420px;
            padding: 50px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(30px);
            border-radius: 40px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: 0 30px 60px -12px rgba(0, 0, 0, 0.08);
            text-align: center;
        }

        .brand {
            font-size: 1.8rem;
            font-weight: 800;
            color: var(--primary);
            letter-spacing: -1.5px;
            margin-bottom: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
        }

        .field {
            margin-bottom: 25px;
            text-align: left;
        }

        label {
            font-size: 0.75rem;
            font-weight: 800;
            color: #86868B;
            margin-left: 15px;
            margin-bottom: 10px;
            display: block;
            text-transform: uppercase;
            letter-spacing: 1.5px;
        }

        input {
            width: 100%;
            padding: 20px 25px;
            border-radius: 22px;
            border: 1px solid rgba(0, 0, 0, 0.05);
            background: var(--white);
            font-size: 1rem;
            box-sizing: border-box;
            transition: 0.4s;
        }

            input:focus {
                outline: none;
                border-color: var(--primary);
                box-shadow: 0 0 0 5px rgba(0, 122, 255, 0.1);
            }

        .btn-submit {
            width: 100%;
            padding: 20px;
            border-radius: 22px;
            border: none;
            background: var(--primary);
            color: white;
            font-size: 1.1rem;
            font-weight: 800;
            cursor: pointer;
            margin-top: 15px;
            box-shadow: 0 15px 30px rgba(0, 122, 255, 0.25);
            transition: 0.4s;
        }

            .btn-submit:hover {
                transform: translateY(-3px);
                box-shadow: 0 20px 40px rgba(0, 122, 255, 0.35);
            }

        .error-msg {
            background: #FF3B30;
            color: white;
            padding: 15px;
            border-radius: 18px;
            font-size: 0.85rem;
            font-weight: 700;
            margin-bottom: 25px;
        }

        .links {
            margin-top: 35px;
            font-size: 0.9rem;
            font-weight: 600;
        }

            .links a {
                color: var(--primary);
                text-decoration: none;
            }
    </style>
</head>
<body>

    <div class="login-box">
        <div class="brand">
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                <path d="M17.8 19.2L16 11l3.5-3.5C21 6 21.5 4 21 3.5c-.5-.5-2.5 0-4 1.5L13.5 8.5 5.3 6.7c-1.1-.3-2.2.4-2.5 1.5l-.5 2 8 3L7 17l-3-1-2 1 4 2 2 4 1-2-1-3 3.8-3.3 3 8 2-.5c1.1-.3 1.8-1.4 1.5-2.5z" />
            </svg>
            AIRPORT.OS
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form asp-action="Login" method="post">
            <div class="field">
                <label>Идентификатор сотрудника</label>
                <input type="email" name="email" placeholder="root@airport.ru" required />
            </div>

            <div class="field">
                <label>Пароль доступа</label>
                <input type="password" name="password" placeholder="••••••••" required />
            </div>

            <button type="submit" class="btn-submit">ВХОД В СИСТЕМУ</button>
        </form>

        <div class="links">
            <a href="/">Вернуться на главную</a>
        </div>
    </div>

</body>
</html>